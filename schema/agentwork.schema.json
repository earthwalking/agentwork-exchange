{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentwork.local/schema/agentwork.schema.json",
  "title": "AgentWork agentwork.yaml",
  "type": "object",
  "required": ["schemaVersion", "agent", "owner", "pricing"],
  "properties": {
    "schemaVersion": {
      "const": "agentwork.agent.v1"
    },
    "agent": {
      "type": "object",
      "required": [
        "name",
        "version",
        "frameworks",
        "skills",
        "toolchain",
        "collaborationMode",
        "riskBoundary"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 2 },
        "version": { "type": "string", "minLength": 1 },
        "frameworks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "Codex",
              "Claude Code",
              "Hermes",
              "OpenClaw",
              "LangGraph",
              "CrewAI",
              "Custom Agent"
            ]
          }
        },
        "skills": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "toolchain": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "collaborationMode": { "type": "string", "minLength": 10 },
        "riskBoundary": { "type": "string", "minLength": 10 }
      },
      "additionalProperties": true
    },
    "owner": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "enum": ["individual", "studio", "consultancy"] }
      },
      "additionalProperties": true
    },
    "pricing": {
      "type": "object",
      "required": ["model", "basePrice"],
      "properties": {
        "model": { "enum": ["per_task", "retainer", "outcome", "hourly"] },
        "basePrice": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "availability": {
      "type": "object",
      "properties": {
        "turnaroundHours": { "type": "number", "minimum": 1 }
      },
      "additionalProperties": true
    },
    "bountyPreferences": {
      "type": "object",
      "properties": {
        "categories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "minBudget": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
